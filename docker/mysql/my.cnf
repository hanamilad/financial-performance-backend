[mysqld]
# Arabic content requires real 4-byte UTF-8 throughout (DEC-002).
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci

default-storage-engine = InnoDB

# `default_authentication_plugin` was removed in MySQL 8.4; the replacement is
# `authentication_policy`. caching_sha2_password is also the 8.4 default, so
# this is stated for explicitness rather than to change behaviour.
authentication_policy = caching_sha2_password

skip-name-resolve

# Local sizing. Production values are decided in Phase 16.
innodb_buffer_pool_size = 256M
# Supersedes innodb_log_file_size, which is deprecated as of MySQL 8.0.30.
innodb_redo_log_capacity = 256M
innodb_flush_log_at_trx_commit = 2
max_connections = 100

# Financial figures are DECIMAL; reject silent truncation and invalid dates
# rather than coercing them.
sql_mode = STRICT_ALL_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION,NO_ZERO_DATE,NO_ZERO_IN_DATE

slow_query_log = 1
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time = 2

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
