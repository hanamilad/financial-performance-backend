APP_NAME="Financial Performance Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Host names and ports below are the Docker network's internal ones.
# From Windows tools (TablePlus/DBeaver) use 127.0.0.1:3307 instead.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=financial_performance
DB_USERNAME=fpp
DB_PASSWORD=

# Laravel defaults to utf8mb4_unicode_ci, which would not match the server
# default set in docker/mysql/my.cnf and invites "illegal mix of collations"
# on joins. Pin both to the MySQL 8 default instead.
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_0900_ai_ci

# Consumed by the mysql service in compose.yaml only, not by Laravel.
MYSQL_ROOT_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave SESSION_DOMAIN unset locally so the cookie binds to the current host.
# In production set it to the shared parent domain of the admin panel and API
# (e.g. .example.com) and set SESSION_SECURE_COOKIE=true over HTTPS.
# SESSION_DOMAIN=
# SESSION_SECURE_COOKIE=true

# Sanctum stateful SPA authentication for the admin web (AUTH-001).
# Hosts listed here receive the session cookie instead of a bearer token.
# Local admin web is expected on port 3000; production hosts are added per
# environment and never guessed here.
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# Browser origins allowed to send credentialed CORS requests to the API.
# Must be explicit (no wildcard) because cookies are shared.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

# From Windows tools use 127.0.0.1:6380 instead.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mailpit — local only. Web UI at http://localhost:8026
# (8026 and not 8025: Laragon already binds 8025 for its own Mailpit.)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@financial-performance.local"
MAIL_FROM_NAME="${APP_NAME}"
